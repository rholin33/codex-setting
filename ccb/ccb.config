version = 2
entry_window = "master"

[windows]
master = "master:codex; loader:codex"
archi = "archi:codex"
coder = "coder1:codex; coder2:codex"
designer = "designer:codex"
reviewer = "reviewer:codex; test:codex"

[ui.sidebar]
agents_height = "50%"
comms_height = "15%"
tips_height = "35%"

[agents.master]
model = "gpt-5.6-terra"
thinking = "high"
role = "agentroles.ccb_self"

[agents.loader]
model = "gpt-5.6-luna"
thinking = "high"
role = "agentroles.ccb_self"

[agents.archi]
model = "gpt-5.6-sol"
thinking = "xhigh"
role = "agentroles.archi"

[agents.coder1]
model = "gpt-5.6-sol"
thinking = "medium"
role = "agentroles.coder"

[agents.coder2]
model = "gpt-5.6-sol"
thinking = "medium"
role = "agentroles.coder"

[agents.designer]
model = "gpt-5.6-sol"
thinking = "xhigh"
role = "agentroles.open_design"

[agents.reviewer]
model = "gpt-5.6-sol"
thinking = "xhigh"
role = "agentroles.code_reviewer"

[agents.test]
model = "gpt-5.6-terra"
role = "agentroles.code_reviewer"
thinking = "high"
